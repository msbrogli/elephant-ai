# My Little Elephant — Configuration
#
# Copy this file to config.yaml and fill in your values.
# Required: llm section and at least one database.

llm:
  base_url: "https://routellm.abacus.ai/v1"   # any OpenAI-compatible endpoint
  api_key: "YOUR_API_KEY"
  morning_model: "claude-sonnet-4-6"            # creative writing (digests)
  parsing_model: "gpt-4.1-mini"                 # fast structured extraction

# Default schedule — databases inherit this unless they override it
schedule:
  morning_digest: "07:00"
  evening_checkin: "20:00"
  timezone: "America/Chicago"

# Pick one provider: "twilio" or "telegram"
messaging:
  provider: "telegram"

  twilio:
    account_sid: ""
    auth_token: ""
    whatsapp_from: "whatsapp:+14155238886"
    whatsapp_to: "whatsapp:+19725551234"

  telegram:
    bot_token: ""
    webhook_secret: ""
    webhook_url: ""        # base URL, e.g. "https://myhost.ngrok.io"
    mode: "webhook"        # "webhook" or "polling"

# Each database is a fully isolated family — own data dir, git repo, and auth.
# User sends /start <auth_secret> to join a specific database.
databases:
  my_family:
    data_dir: "/app/data/my_family"
    auth_secret: ""        # user sends /start <this> to authenticate
    # schedule:            # optional — overrides top-level schedule
    #   morning_digest: "08:30"
    #   evening_checkin: "21:00"
    #   timezone: "America/New_York"
